<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>红蓝小人剑弓对决 - 增强版</title>
    <style>
        body {
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #1a1a2e;
            color: white;
            font-family: Arial, sans-serif;
            overflow: hidden;
        }
        
        #gameCanvas {
            border: 3px solid #fff;
            background: linear-gradient(to bottom, #16213e 0%, #0f3460 100%);
            margin-top: 20px;
        }
        
        #controls {
            margin-top: 10px;
            display: flex;
            gap: 50px;
            text-align: center;
        }
        
        .player-controls {
            padding: 10px;
            border-radius: 10px;
        }
        
        #red-controls {
            background: rgba(231, 76, 60, 0.3);
            border: 2px solid #e74c3c;
        }
        
        #blue-controls {
            background: rgba(52, 152, 219, 0.3);
            border: 2px solid #3498db;
        }
        
        h2 {
            margin: 5px 0;
        }
        
        .key {
            display: inline-block;
            padding: 3px 8px;
            background: #333;
            border-radius: 4px;
            margin: 2px;
            font-weight: bold;
        }
        
        #gameOver {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.9);
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            display: none;
            z-index: 10;
        }
        
        button {
            padding: 10px 20px;
            font-size: 18px;
            margin-top: 15px;
            cursor: pointer;
            background: #e74c3c;
            color: white;
            border: none;
            border-radius: 5px;
        }
        
        button:hover {
            background: #c0392b;
        }
        
        #ammo-display {
            position: absolute;
            top: 10px;
            display: flex;
            gap: 200px;
            font-size: 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <h1>⚔️ 红蓝对决 - 增强版 🏹</h1>
    
    <div style="position: relative;">
        <canvas id="gameCanvas" width="1200" height="600"></canvas>
        <div id="ammo-display">
            <span style="color: #e74c3c;">🔴 弓箭: <span id="red-arrows">5</span>/5</span>
            <span style="color: #3498db;">🔵 弓箭: <span id="blue-arrows">5</span>/5</span>
        </div>
    </div>
    
    <div id="controls">
        <div class="player-controls" id="red-controls">
            <h2>🔴 红色玩家</h2>
            <p>移动: <span class="key">W</span><span class="key">A</span><span class="key">S</span><span class="key">D</span> (W跳跃,可连跳)</p>
            <p>剑攻击: <span class="key">1</span> | 弓箭: <span class="key">2</span></p>
            <p>生命: <span id="red-hp">❤️❤️❤️❤️❤️❤️</span></p>
        </div>
        <div class="player-controls" id="blue-controls">
            <h2>🔵 蓝色玩家</h2>
            <p>移动: <span class="key">↑</span><span class="key">←</span><span class="key">↓</span><span class="key">→</span> (↑跳跃,可连跳)</p>
            <p>剑攻击: <span class="key">,</span> | 弓箭: <span class="key">.</span></p>
            <p>生命: <span id="blue-hp">❤️❤️❤️❤️❤️❤️</span></p>
        </div>
    </div>
    
    <div id="gameOver">
        <h1 id="winner"></h1>
        <button onclick="resetGame()">重新开始</button>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        // 游戏状态
        let gameRunning = true;
        const gravity = 0.5;
        const groundY = 550;
        
        // 地图元素 - 重新设计更合理的跳板高度
        const platforms = [
            // 地面坑洞 (x, y, width, height, type)
            {x: 0, y: groundY, width: 300, height: 50, type: 'ground'},
            {x: 400, y: groundY, width: 400, height: 50, type: 'ground'},
            {x: 900, y: groundY, width: 300, height: 50, type: 'ground'},
            
            // 第一层跳板 - 容易跳上去 (高度差60-80px)
            {x: 150, y: 480, width: 120, height: 20, type: 'platform', jumpBoost: false},
            {x: 350, y: 450, width: 120, height: 20, type: 'platform', jumpBoost: false},
            {x: 550, y: 480, width: 120, height: 20, type: 'platform', jumpBoost: false},
            {x: 750, y: 450, width: 120, height: 20, type: 'platform', jumpBoost: false},
            {x: 950, y: 480, width: 120, height: 20, type: 'platform', jumpBoost: false},
            
            // 第二层跳板 - 中等高度 (从第一层可轻松跳上去)
            {x: 250, y: 380, width: 100, height: 20, type: 'platform', jumpBoost: true},
            {x: 500, y: 350, width: 120, height: 20, type: 'platform', jumpBoost: true},
            {x: 800, y: 380, width: 100, height: 20, type: 'platform', jumpBoost: true},
            
            // 第三层跳板 - 高台 (从第二层跳上去)
            {x: 400, y: 280, width: 100, height: 20, type: 'platform', jumpBoost: true},
            {x: 650, y: 280, width: 100, height: 20, type: 'platform', jumpBoost: true},
            
            // 最高层 - 中央制高点 (需要连续跳跃)
            {x: 525, y: 200, width: 100, height: 20, type: 'platform', jumpBoost: true},
        ];
        
        // 坑洞（掉下去即死）
        const pits = [
            {x: 300, y: groundY, width: 100, height: 100},
            {x: 800, y: groundY, width: 100, height: 100}
        ];
        
        // 玩家对象
        const player1 = {
            x: 150,
            y: groundY - 40,
            width: 30,
            height: 40,
            color: '#e74c3c',
            vx: 0,
            vy: 0,
            speed: 5,
            jumpPower: -12,
            hp: 6,
            maxHp: 6,
            facing: 1,
            attacking: false,
            attackTimer: 0,
            attackType: '',
            onGround: false,
            invincible: 0,
            arrowsLeft: 5,  // 改为5发
            maxArrows: 5,   // 改为5发
            swordLength: 5,
            onPlatform: false,
            jumpBoosted: false
        };
        
        const player2 = {
            x: 1050,
            y: groundY - 40,
            width: 30,
            height: 40,
            color: '#3498db',
            vx: 0,
            vy: 0,
            speed: 5,
            jumpPower: -12,
            hp: 6,
            maxHp: 6,
            facing: -1,
            attacking: false,
            attackTimer: 0,
            attackType: '',
            onGround: false,
            invincible: 0,
            arrowsLeft: 5,  // 改为5发
            maxArrows: 5,   // 改为5发
            swordLength: 5,
            onPlatform: false,
            jumpBoosted: false
        };
        
        // 箭矢数组
        let arrows = [];
        
        // 按键状态
        const keys = {};
        
        // 监听键盘
        document.addEventListener('keydown', (e) => {
            keys[e.key] = true;
            
            // 红色玩家攻击
            if (e.key === '1' && gameRunning) player1Attack('sword');
            if (e.key === '2' && gameRunning) player1Attack('bow');
            
            // 蓝色玩家攻击 (逗号和句号)
            if (e.key === ',' && gameRunning) player2Attack('sword');
            if (e.key === '.' && gameRunning) player2Attack('bow');
        });
        
        document.addEventListener('keyup', (e) => {
            keys[e.key] = false;
        });
        
        // 红色玩家攻击
        function player1Attack(type) {
            if (player1.attacking) return;
            
            if (type === 'bow' && player1.arrowsLeft <= 0) return;
            
            player1.attacking = true;
            player1.attackType = type;
            player1.attackTimer = type === 'sword' ? 25 : 15;
            
            if (type === 'bow') {
                player1.arrowsLeft--;
                updateAmmo();
                arrows.push({
                    x: player1.x + (player1.facing === 1 ? 30 : 0),
                    y: player1.y + 15,
                    vx: player1.facing * 12,
                    vy: 0,
                    owner: 1,
                    color: '#e74c3c'
                });
            }
        }
        
        // 蓝色玩家攻击
        function player2Attack(type) {
            if (player2.attacking) return;
            
            if (type === 'bow' && player2.arrowsLeft <= 0) return;
            
            player2.attacking = true;
            player2.attackType = type;
            player2.attackTimer = type === 'sword' ? 25 : 15;
            
            if (type === 'bow') {
                player2.arrowsLeft--;
                updateAmmo();
                arrows.push({
                    x: player2.x + (player2.facing === 1 ? 30 : 0),
                    y: player2.y + 15,
                    vx: player2.facing * 12,
                    vy: 0,
                    owner: 2,
                    color: '#3498db'
                });
            }
        }
        
        // 碰撞检测
        function checkCollision(rect1, rect2) {
            return rect1.x < rect2.x + rect2.width &&
                   rect1.x + rect1.width > rect2.x &&
                   rect1.y < rect2.y + rect2.height &&
                   rect1.y + rect1.height > rect2.y;
        }
        
        // 更新游戏
        function update() {
            if (!gameRunning) return;
            
            // 红色玩家移动 (WASD)
            if (keys['a'] || keys['A']) {
                player1.vx = -player1.speed;
                player1.facing = -1;
            } else if (keys['d'] || keys['D']) {
                player1.vx = player1.speed;
                player1.facing = 1;
            } else {
                player1.vx *= 0.8;
            }
            
            // 红色跳跃 (W) - 允许连跳
            if ((keys['w'] || keys['W']) && !player1.jumpKeyHeld) {
                if (player1.onGround || player1.onPlatform) {
                    player1.vy = player1.jumpPower;
                    player1.onGround = false;
                    player1.onPlatform = false;
                    player1.jumpKeyHeld = true;
                    
                    // 踏板弹跳加成
                    if (player1.jumpBoosted) {
                        player1.vy *= 1.4;
                        player1.jumpBoosted = false;
                    }
                }
            }
            if (!(keys['w'] || keys['W'])) {
                player1.jumpKeyHeld = false;
            }
            
            // 蓝色玩家移动 (方向键)
            if (keys['ArrowLeft']) {
                player2.vx = -player2.speed;
                player2.facing = -1;
            } else if (keys['ArrowRight']) {
                player2.vx = player2.speed;
                player2.facing = 1;
            } else {
                player2.vx *= 0.8;
            }
            
            // 蓝色跳跃 (↑) - 允许连跳
            if (keys['ArrowUp'] && !player2.jumpKeyHeld) {
                if (player2.onGround || player2.onPlatform) {
                    player2.vy = player2.jumpPower;
                    player2.onGround = false;
                    player2.onPlatform = false;
                    player2.jumpKeyHeld = true;
                    
                    // 踏板弹跳加成
                    if (player2.jumpBoosted) {
                        player2.vy *= 1.4;
                        player2.jumpBoosted = false;
                    }
                }
            }
            if (!keys['ArrowUp']) {
                player2.jumpKeyHeld = false;
            }
            
            // 物理更新
            [player1, player2].forEach(p => {
                p.vy += gravity;
                p.x += p.vx;
                p.y += p.vy;
                
                p.onGround = false;
                p.onPlatform = false;
                p.jumpBoosted = false;
                
                // 平台碰撞检测
                platforms.forEach(plat => {
                    if (checkCollision(p, plat)) {
                        // 从上方落下
                        if (p.vy > 0 && p.y + p.height - p.vy <= plat.y + 10) {
                            p.y = plat.y - p.height;
                            p.vy = 0;
                            
                            if (plat.type === 'ground') {
                                p.onGround = true;
                            } else {
                                p.onPlatform = true;
                                if (plat.jumpBoost) {
                                    p.jumpBoosted = true;
                                }
                            }
                        }
                    }
                });
                
                // 坑洞检测（掉下去即死）
                pits.forEach(pit => {
                    if (p.x > pit.x && p.x + p.width < pit.x + pit.width && p.y > groundY) {
                        p.hp = 0;
                        updateHP();
                        checkWin();
                    }
                });
                
                // 边界限制
                if (p.x < 0) p.x = 0;
                if (p.x > canvas.width - p.width) p.x = canvas.width - p.width;
                
                // 无敌时间递减
                if (p.invincible > 0) p.invincible--;
                
                // 攻击计时器
                if (p.attackTimer > 0) {
                    p.attackTimer--;
                    if (p.attackTimer === 0) p.attacking = false;
                }
                
                // 防止掉出画布底部
                if (p.y > canvas.height) {
                    p.hp = 0;
                    updateHP();
                    checkWin();
                }
            });
            
            // 剑攻击检测
            checkSwordHit(player1, player2);
            checkSwordHit(player2, player1);
            
            // 箭矢更新
            for (let i = arrows.length - 1; i >= 0; i--) {
                let arrow = arrows[i];
                arrow.x += arrow.vx;
                arrow.y += arrow.vy;
                
                // 箭矢与平台碰撞
                let hitPlatform = false;
                platforms.forEach(plat => {
                    if (arrow.x > plat.x && arrow.x < plat.x + plat.width &&
                        arrow.y > plat.y && arrow.y < plat.y + plat.height) {
                        hitPlatform = true;
                    }
                });
                
                // 检测击中玩家
                let target = arrow.owner === 1 ? player2 : player1;
                if (!hitPlatform && 
                    arrow.x > target.x && arrow.x < target.x + target.width &&
                    arrow.y > target.y && arrow.y < target.y + target.height) {
                    if (target.invincible === 0) {
                        target.hp--;
                        target.invincible = 60;
                        updateHP();
                        checkWin();
                    }
                    arrows.splice(i, 1);
                    continue;
                }
                
                // 移除超出边界或击中平台的箭
                if (arrow.x < 0 || arrow.x > canvas.width || hitPlatform) {
                    arrows.splice(i, 1);
                }
            }
        }
        
        // 剑攻击检测
        function checkSwordHit(attacker, target) {
            if (!attacker.attacking || attacker.attackType !== 'sword') return;
            if (attacker.attackTimer !== 18) return;
            
            const swordLength = 50;
            const swordWidth = 12;
            
            let attackX = attacker.facing === 1 ? attacker.x + attacker.width : attacker.x - swordLength;
            let attackY = attacker.y + 10;
            
            if (attackX < target.x + target.width && attackX + swordLength > target.x &&
                attackY < target.y + target.height && attackY + swordWidth > target.y) {
                if (target.invincible === 0) {
                    target.hp--;
                    target.invincible = 60;
                    target.vx = attacker.facing * 12;
                    target.vy = -8;
                    updateHP();
                    checkWin();
                }
            }
        }
        
        // 绘制游戏
        function draw() {
            // 清空画布
            ctx.fillStyle = '#0f3460';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // 绘制背景装饰
            ctx.fillStyle = 'rgba(255,255,255,0.05)';
            for(let i=0; i<10; i++) {
                ctx.fillRect(i*150, 100 + Math.sin(i)*50, 80, 80);
            }
            
            // 绘制坑洞（黑色深渊）
            ctx.fillStyle = '#000';
            pits.forEach(pit => {
                ctx.fillRect(pit.x, pit.y, pit.width, canvas.height - pit.y);
                ctx.fillStyle = '#e74c3c';
                ctx.fillRect(pit.x, pit.y, 5, 10);
                ctx.fillRect(pit.x + pit.width - 5, pit.y, 5, 10);
                ctx.fillStyle = '#000';
            });
            
            // 绘制平台
            platforms.forEach(plat => {
                if (plat.type === 'ground') {
                    ctx.fillStyle = '#2ecc71';
                    ctx.fillRect(plat.x, plat.y, plat.width, plat.height);
                    ctx.fillStyle = '#27ae60';
                    ctx.fillRect(plat.x, plat.y, plat.width, 5);
                } else {
                    if (plat.jumpBoost) {
                        // 弹跳踏板 - 金色
                        ctx.fillStyle = '#f1c40f';
                        ctx.fillRect(plat.x, plat.y, plat.width, plat.height);
                        ctx.fillStyle = '#f39c12';
                        ctx.fillRect(plat.x, plat.y + 15, plat.width, 5);
                        ctx.fillStyle = '#fff';
                        ctx.font = '16px Arial';
                        ctx.fillText('↑', plat.x + plat.width/2 - 8, plat.y - 5);
                    } else {
                        // 普通平台 - 灰色
                        ctx.fillStyle = '#95a5a6';
                        ctx.fillRect(plat.x, plat.y, plat.width, plat.height);
                        ctx.fillStyle = '#7f8c8d';
                        ctx.fillRect(plat.x, plat.y + 15, plat.width, 5);
                    }
                }
            });
            
            // 绘制玩家
            drawPlayer(player1);
            drawPlayer(player2);
            
            // 绘制箭矢
            arrows.forEach(arrow => {
                ctx.save();
                ctx.translate(arrow.x, arrow.y);
                ctx.rotate(arrow.vx > 0 ? 0 : Math.PI);
                
                ctx.fillStyle = arrow.color;
                ctx.fillRect(-10, -2, 20, 4);
                
                ctx.beginPath();
                ctx.moveTo(10, -4);
                ctx.lineTo(18, 0);
                ctx.lineTo(10, 4);
                ctx.fill();
                
                ctx.fillStyle = '#fff';
                ctx.beginPath();
                ctx.moveTo(-10, -2);
                ctx.lineTo(-15, -6);
                ctx.lineTo(-12, -2);
                ctx.fill();
                ctx.beginPath();
                ctx.moveTo(-10, 2);
                ctx.lineTo(-15, 6);
                ctx.lineTo(-12, 2);
                ctx.fill();
                
                ctx.restore();
            });
        }
        
        // 绘制玩家
        function drawPlayer(p) {
            ctx.save();
            
            if (p.invincible > 0 && Math.floor(p.invincible / 5) % 2 === 0) {
                ctx.globalAlpha = 0.5;
            }
            
            // 身体
            ctx.fillStyle = p.color;
            ctx.fillRect(p.x, p.y, p.width, p.height);
            
            // 头盔
            ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.fillRect(p.x + 5, p.y + 5, p.width - 10, 10);
            
            // 眼睛
            ctx.fillStyle = 'white';
            let eyeX = p.facing === 1 ? p.x + 20 : p.x + 5;
            ctx.fillRect(eyeX, p.y + 8, 5, 5);
            ctx.fillStyle = 'black';
            ctx.fillRect(eyeX + (p.facing === 1 ? 2 : 0), p.y + 9, 3, 3);
            
            // 帅气的长剑
            const swordLength = 50;
            
            if (p.attacking && p.attackType === 'sword') {
                ctx.save();
                ctx.translate(p.x + p.width/2, p.y + 25);
                
                let progress = (25 - p.attackTimer) / 25;
                let angle = p.facing === 1 ? 
                    -Math.PI/3 + progress * Math.PI/1.5 : 
                    Math.PI/3 - progress * Math.PI/1.5;
                
                ctx.rotate(angle);
                
                ctx.strokeStyle = 'rgba(255,255,255,0.5)';
                ctx.lineWidth = 8;
                ctx.beginPath();
                ctx.arc(0, 0, swordLength/2, -Math.PI/4, Math.PI/4);
                ctx.stroke();
                
                ctx.fillStyle = '#8b4513';
                ctx.fillRect(-5, -3, 15, 6);
                
                ctx.fillStyle = '#f1c40f';
                ctx.fillRect(8, -8, 6, 16);
                
                ctx.fillStyle = '#bdc3c7';
                ctx.fillRect(12, -4, swordLength, 8);
                
                ctx.fillStyle = '#ecf0f1';
                ctx.fillRect(12, -2, swordLength, 3);
                
                ctx.fillStyle = '#bdc3c7';
                ctx.beginPath();
                ctx.moveTo(12 + swordLength, -4);
                ctx.lineTo(12 + swordLength + 8, 0);
                ctx.lineTo(12 + swordLength, 4);
                ctx.fill();
                
                ctx.restore();
            } else {
                ctx.save();
                ctx.translate(p.x + (p.facing === 1 ? 25 : 5), p.y + 20);
                ctx.rotate(p.facing === 1 ? 0 : Math.PI);
                
                ctx.fillStyle = '#8b4513';
                ctx.fillRect(-5, -3, 15, 6);
                
                ctx.fillStyle = '#f1c40f';
                ctx.fillRect(8, -8, 6, 16);
                
                ctx.fillStyle = '#95a5a6';
                ctx.fillRect(12, -4, swordLength, 8);
                
                ctx.fillStyle = '#bdc3c7';
                ctx.fillRect(12, -2, swordLength, 3);
                
                ctx.fillStyle = '#95a5a6';
                ctx.beginPath();
                ctx.moveTo(12 + swordLength, -4);
                ctx.lineTo(12 + swordLength + 8, 0);
                ctx.lineTo(12 + swordLength, 4);
                ctx.fill();
                
                ctx.restore();
            }
            
            // 弓
            ctx.strokeStyle = '#8b4513';
            ctx.lineWidth = 3;
            ctx.beginPath();
            ctx.arc(p.x + (p.facing === 1 ? -5 : 35), p.y + 20, 12, Math.PI/2, -Math.PI/2, true);
            ctx.stroke();
            
            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(p.x + (p.facing === 1 ? -5 : 35), p.y + 8);
            ctx.lineTo(p.x + (p.facing === 1 ? -5 : 35), p.y + 32);
            ctx.stroke();
            
            // 生命指示器
            ctx.fillStyle = 'white';
            ctx.font = 'bold 14px Arial';
            ctx.fillText('HP:' + p.hp, p.x - 5, p.y - 8);
            
            // 弹药指示
            if (p.arrowsLeft > 0) {
                ctx.fillStyle = '#f1c40f';
                for(let i=0; i<p.arrowsLeft; i++) {
                    ctx.fillRect(p.x + i*8, p.y - 20, 6, 3);
                }
            }
            
            ctx.restore();
        }
        
        // 更新生命显示
        function updateHP() {
            document.getElementById('red-hp').textContent = '❤️'.repeat(player1.hp) + '🖤'.repeat(player1.maxHp-player1.hp);
            document.getElementById('blue-hp').textContent = '❤️'.repeat(player2.hp) + '🖤'.repeat(player2.maxHp-player2.hp);
        }
        
        // 更新弹药显示
        function updateAmmo() {
            document.getElementById('red-arrows').textContent = player1.arrowsLeft;
            document.getElementById('blue-arrows').textContent = player2.arrowsLeft;
        }
        
        // 检查胜利
        function checkWin() {
            if (player1.hp <= 0) {
                endGame('🔵 蓝色玩家获胜！');
            } else if (player2.hp <= 0) {
                endGame('🔴 红色玩家获胜！');
            }
        }
        
        // 游戏结束
        function endGame(winnerText) {
            gameRunning = false;
            document.getElementById('winner').textContent = winnerText;
            document.getElementById('gameOver').style.display = 'block';
        }
        
        // 重置游戏
        function resetGame() {
            player1.x = 150;
            player1.y = groundY - 40;
            player1.hp = player1.maxHp;
            player1.vx = 0;
            player1.vy = 0;
            player1.facing = 1;
            player1.arrowsLeft = player1.maxArrows;
            player1.attacking = false;
            player1.attackTimer = 0;
            
            player2.x = 1050;
            player2.y = groundY - 40;
            player2.hp = player2.maxHp;
            player2.vx = 0;
            player2.vy = 0;
            player2.facing = -1;
            player2.arrowsLeft = player2.maxArrows;
            player2.attacking = false;
            player2.attackTimer = 0;
            
            arrows = [];
            gameRunning = true;
            document.getElementById('gameOver').style.display = 'none';
            updateHP();
            updateAmmo();
        }
        
        // 游戏循环
        function gameLoop() {
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }
        
        gameLoop();
    </script>
</body>
</html>
